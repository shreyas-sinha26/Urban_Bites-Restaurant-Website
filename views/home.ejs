<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ortensia - Welcome</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;1,600&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: linear-gradient(rgba(0, 0, 0, 0.55), rgba(0, 0, 0, 0.75)), url('https://dt4l9bx31tioh.cloudfront.net/eazymedia/restaurant/657972/restaurant220240216043525.jpg') no-repeat center center;
            background-size: cover; height: 100vh; font-family: 'Poppins', sans-serif; overflow: hidden;
        }
        .title-font { font-family: 'Playfair Display', serif; }
        .btn { position: relative; overflow: hidden; transition: all 0.3s ease; }
        .btn::after {
            content: ''; position: absolute; bottom: 0; left: 0; width: 100%; height: 0%;
            background-color: rgba(255, 255, 255, 0.15); transition: all 0.3s ease; z-index: 1;
        }
        .btn:hover::after { height: 100%; }
        .btn span { position: relative; z-index: 2; }
        .gsap-reveal { opacity: 0; transform: translateY(40px); }
        .gsap-scale { opacity: 0; transform: scale(0.8); }
    </style>
</head>
<body class="flex flex-col items-center justify-center text-white text-center px-4">

    <div class="fixed top-8 left-1/2 transform -translate-x-1/2 z-50 flex flex-col gap-4 w-11/12 max-w-md pointer-events-none">
        <% if(typeof success !== 'undefined' && success.length > 0) { %>
            <div class="bg-white/95 backdrop-blur-md px-6 py-4 rounded-full shadow-xl flex items-center gap-3 text-green-600 font-medium text-sm border-l-4 border-green-500 opacity-0 flash-msg transform -translate-y-8">
                <span class="text-lg">✅</span> <span><%= success %></span>
            </div>
        <% } %>
        <% if(typeof error !== 'undefined' && error.length > 0) { %>
            <div class="bg-white/95 backdrop-blur-md px-6 py-4 rounded-full shadow-xl flex items-center gap-3 text-red-500 font-medium text-sm border-l-4 border-red-500 opacity-0 flash-msg transform -translate-y-8">
                <span class="text-lg">⚠️</span> <span><%= error %></span>
            </div>
        <% } %>
    </div>

    <div class="max-w-3xl w-full flex flex-col items-center">
        <span class="gsap-reveal bg-orange-500/20 text-orange-400 border border-orange-500/30 px-4 py-1.5 rounded-full text-sm font-medium tracking-widest uppercase mb-6">
            Taste the Extraordinary
        </span>
        <h1 class="gsap-reveal title-font text-6xl md:text-8xl font-bold mb-4 drop-shadow-2xl text-white tracking-tight">
            Ōrten<span class="text-orange-500 italic font-medium">sia</span>
        </h1>
        <p class="gsap-reveal text-lg md:text-2xl text-gray-200 font-light mb-12 max-w-2xl drop-shadow-md">
            Discover a world of exquisite flavors and unforgettable dining experiences. Your table is waiting.
        </p>

        <div class="flex flex-col sm:flex-row gap-5 w-full sm:w-auto justify-center">
            <a href="/signup" class="gsap-scale btn bg-orange-500 text-white px-10 py-4 rounded-full font-semibold text-lg shadow-lg shadow-orange-500/30 hover:bg-orange-600 hover:-translate-y-1 w-full sm:w-auto text-center border border-transparent">
                <span>Create an Account</span>
            </a>
            <a href="/login" class="gsap-scale btn bg-white/10 backdrop-blur-md text-white px-10 py-4 rounded-full font-semibold text-lg shadow-lg hover:bg-white/20 hover:-translate-y-1 border border-white/30 w-full sm:w-auto text-center">
                <span>Log In</span>
            </a>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            gsap.to(".gsap-reveal", { duration: 1, opacity: 1, y: 0, stagger: 0.2, ease: "power3.out", delay: 0.2 });
            gsap.to(".gsap-scale", { duration: 0.8, opacity: 1, scale: 1, stagger: 0.15, ease: "back.out(1.5)", delay: 0.8 });

            const flashMessages = document.querySelectorAll(".flash-msg");
            if (flashMessages.length > 0) {
                gsap.timeline()
                    .to(".flash-msg", { duration: 0.6, opacity: 1, y: 0, stagger: 0.15, ease: "back.out(1.5)", delay: 0.5 })
                    .to(".flash-msg", { duration: 0.5, opacity: 0, y: -30, stagger: 0.1, ease: "power2.in", delay: 3.5 });
            }
        });
    </script>
</body>
</html>