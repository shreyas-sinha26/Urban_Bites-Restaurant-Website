<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Ōrtensia</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;1,600&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <script src="https://cdn.tailwindcss.com"></script>
    
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #fafafa;
            color: #333;
        }
        
        .title-font { font-family: 'Playfair Display', serif; }
        
        .hero-section {
            background: linear-gradient(to bottom, rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.7)), 
                        url('https://dt4l9bx31tioh.cloudfront.net/eazymedia/restaurant/657972/restaurant220240216043525.jpg') no-repeat center center;
            background-size: cover;
            background-attachment: fixed;
            height: 70vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: white;
        }

        /* Glassmorphism Navbar */
        .navbar {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.3);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.05);
        }
        
        /* Custom Underline Animation for Nav Links */
        .nav-link {
            position: relative;
            color: #4a4a4a;
            transition: color 0.3s ease;
        }
        .nav-link::after {
            content: '';
            position: absolute;
            width: 0%;
            height: 2px;
            bottom: -4px;
            left: 0;
            background-color: #f97316; /* Orange accent */
            transition: width 0.3s ease;
        }
        .nav-link:hover { color: #f97316; }
        .nav-link:hover::after { width: 100%; }

        /* Card Hover Effects */
        .feature-card { transition: transform 0.4s ease, box-shadow 0.4s ease; }
        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }

        /* Initial states for GSAP animations */
        .gsap-nav { opacity: 0; transform: translateY(-20px); }
        .gsap-hero { opacity: 0; transform: translateY(30px); }
        .gsap-card { opacity: 0; transform: translateY(40px); }
        
        /* Floating Flash Messages */
        .flash-container {
            position: fixed; top: 90px; left: 50%; transform: translateX(-50%); z-index: 1000;
            display: flex; flex-direction: column; gap: 15px; pointer-events: none; width: 90%; max-width: 400px;
        }
        .flash-message {
            background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); padding: 16px 24px; border-radius: 50px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2); display: flex; align-items: center; gap: 12px;
            font-weight: 500; font-size: 15px; opacity: 0; transform: translateY(-30px);
        }
        .flash-message.error { color: #d9534f; border-left: 5px solid #d9534f; }
        .flash-message.success { color: #28a745; border-left: 5px solid #28a745; }
    </style>
</head>
<body>

    <div class="flash-container">
        <% if(typeof error !== 'undefined' && error.length > 0) { %>
            <div class="flash-message error"><span>⚠️</span> <span><%= error %></span></div>
        <% } %>
        <% if(typeof success !== 'undefined' && success.length > 0) { %>
            <div class="flash-message success"><span>✅</span> <span><%= success %></span></div>
        <% } %>
    </div>

    <nav class="navbar fixed top-0 w-full z-50 transition-all duration-300">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <div class="flex-shrink-0 gsap-nav">
                    <a href="/index" class="title-font text-2xl font-bold text-gray-800 tracking-tight">
                        Ōrten<span class="text-orange-500 italic">sia</span>
                    </a>
                </div>
                
                <div class="hidden md:flex space-x-8 items-center gsap-nav">
                    <a href="/index" class="nav-link font-medium text-orange-500">Home</a>
                    <a href="/menu" class="nav-link font-medium">Menu</a>
                    <a href="/delivery" class="nav-link font-medium">Delivery</a>
                    <a href="/reservation" class="nav-link font-medium">Reservations</a>
                    
                    <div class="pl-4 border-l border-gray-300 flex items-center gap-4">
                        <% if(typeof currentUser !== 'undefined' && currentUser) { %>
                            <span class="text-sm font-medium text-gray-500">Hi, <%= currentUser.username %></span>
                            <a href="/logout" class="bg-gray-800 text-white px-5 py-2 rounded-full text-sm font-medium hover:bg-orange-500 transition-colors shadow-md">Log Out</a>
                        <% } else { %>
                            <a href="/login" class="bg-orange-500 text-white px-5 py-2 rounded-full text-sm font-medium hover:bg-orange-600 transition-colors shadow-md shadow-orange-500/30">Log In</a>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <header class="hero-section">
        <div class="max-w-4xl px-4 pt-10">
            <h1 class="gsap-hero title-font text-5xl md:text-7xl font-bold mb-6 drop-shadow-lg">
                <% if(typeof currentUser !== 'undefined' && currentUser) { %>
                    Welcome back to <span class="text-orange-400 italic">Ōrtensia</span>, <%= currentUser.username %>
                <% } else { %>
                    Experience <span class="text-orange-400 italic">Ōrtensia</span>
                <% } %>
            </h1>
            <p class="gsap-hero text-lg md:text-xl font-light text-gray-200 mb-10 drop-shadow-md">
                Elevating culinary traditions with modern flair. Choose your dining experience today.
            </p>
            <div class="gsap-hero flex flex-col sm:flex-row gap-4 justify-center">
                <a href="/reservation" class="bg-orange-500 hover:bg-orange-600 text-white px-8 py-3 rounded-full font-medium transition-transform hover:-translate-y-1 shadow-lg shadow-orange-500/40">Book a Table</a>
                <a href="/menu" class="bg-white/20 hover:bg-white/30 backdrop-blur-md border border-white/40 text-white px-8 py-3 rounded-full font-medium transition-transform hover:-translate-y-1 shadow-lg">Explore Menu</a>
            </div>
        </div>
    </header>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
        <div class="text-center mb-16 gsap-card">
            <span class="text-orange-500 font-semibold tracking-wider uppercase text-sm">Services</span>
            <h2 class="title-font text-4xl font-bold text-gray-800 mt-2">How can we serve you?</h2>
            <div class="h-1 w-20 bg-orange-500 mx-auto mt-6 rounded-full"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
            <div class="feature-card bg-white rounded-2xl overflow-hidden shadow-lg border border-gray-100 gsap-card group">
                <div class="h-48 overflow-hidden relative">
                    <div class="absolute inset-0 bg-black/20 group-hover:bg-transparent transition-colors duration-300 z-10"></div>
                    <img src="/img/petr-sevcovic-qE1jxYXiwOA-unsplash.jpg" alt="Menu" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                </div>
                <div class="p-8 text-center flex flex-col h-full">
                    <h3 class="title-font text-2xl font-bold text-gray-800 mb-3">Our Menu</h3>
                    <p class="text-gray-500 text-sm mb-8 flex-grow">Discover our carefully curated dishes, crafted with locally sourced, seasonal ingredients.</p>
                    <a href="/menu" class="inline-block border-2 border-gray-800 text-gray-800 font-medium px-6 py-2 rounded-full hover:bg-gray-800 hover:text-white transition-colors">View Menu</a>
                </div>
            </div>

            <div class="feature-card bg-white rounded-2xl overflow-hidden shadow-lg border border-gray-100 gsap-card group">
                <div class="h-48 overflow-hidden relative">
                    <div class="absolute inset-0 bg-black/20 group-hover:bg-transparent transition-colors duration-300 z-10"></div>
                    <img src="/img/lily-banse--YHSwy6uqvk-unsplash.jpg" alt="Delivery" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                </div>
                <div class="p-8 text-center flex flex-col h-full">
                    <h3 class="title-font text-2xl font-bold text-gray-800 mb-3">Order Delivery</h3>
                    <p class="text-gray-500 text-sm mb-8 flex-grow">Enjoy Ōrtensia's signature flavors from the comfort of your own home. Fast and fresh.</p>
                    <a href="/delivery" class="inline-block border-2 border-gray-800 text-gray-800 font-medium px-6 py-2 rounded-full hover:bg-gray-800 hover:text-white transition-colors">Order Now</a>
                </div>
            </div>

            <div class="feature-card bg-white rounded-2xl overflow-hidden shadow-lg border border-gray-100 gsap-card group">
                <div class="h-48 overflow-hidden relative">
                    <div class="absolute inset-0 bg-black/20 group-hover:bg-transparent transition-colors duration-300 z-10"></div>
                    <img src="/img/brooke-lark-aGjP08-HbYY-unsplash.jpg" alt="Reservation" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                </div>
                <div class="p-8 text-center flex flex-col h-full">
                    <h3 class="title-font text-2xl font-bold text-gray-800 mb-3">Book a Table</h3>
                    <p class="text-gray-500 text-sm mb-8 flex-grow">Reserve your spot for an unforgettable evening of ambiance, fine wine, and exquisite cuisine.</p>
                    <a href="/reservation" class="inline-block border-2 border-gray-800 text-gray-800 font-medium px-6 py-2 rounded-full hover:bg-gray-800 hover:text-white transition-colors">Book Now</a>
                </div>
            </div>
        </div>
    </section>

    <footer class="bg-gray-900 text-gray-400 py-12 mt-10">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <h2 class="title-font text-3xl font-bold text-white mb-2">Ōrten<span class="text-orange-500 italic">sia</span></h2>
            <p class="text-sm opacity-60">© 2024 Ōrtensia Restaurant. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // Flash Message Toast Animation
            const flashMessages = document.querySelectorAll(".flash-message");
            if (flashMessages.length > 0) {
                gsap.timeline()
                    .to(".flash-message", { duration: 0.6, opacity: 1, y: 0, stagger: 0.15, ease: "back.out(1.5)", delay: 0.5 })
                    .to(".flash-message", { duration: 0.5, opacity: 0, y: -30, stagger: 0.1, ease: "power2.in", delay: 3.5 });
            }

            // Navbar items sliding down
            gsap.to(".gsap-nav", {
                duration: 0.8,
                opacity: 1,
                y: 0,
                stagger: 0.1,
                ease: "power3.out"
            });

            // Hero section elements floating up
            gsap.to(".gsap-hero", {
                duration: 1,
                opacity: 1,
                y: 0,
                stagger: 0.2,
                ease: "power3.out",
                delay: 0.3
            });

            // Service Cards popping up sequentially
            gsap.to(".gsap-card", {
                duration: 0.8,
                opacity: 1,
                y: 0,
                stagger: 0.15,
                ease: "power3.out",
                delay: 0.6
            });
        });
    </script>
</body>
</html>