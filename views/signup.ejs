<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - Urban Bites</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }
        body {
            background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 99%, #fecfef 100%);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        .form-container {
            background: rgba(255, 255, 255, 0.9);
            padding: 40px 30px;
            border-radius: 15px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 400px;
            text-align: center;
            /* Initially hidden for GSAP */
            opacity: 0; 
            transform: translateY(30px);
        }
        .form-container h2 {
            font-size: 28px;
            color: #333;
            margin-bottom: 30px;
        }
        .input-group {
            margin-bottom: 20px;
            text-align: left;
            /* Initially hidden for GSAP */
            opacity: 0; 
            transform: translateY(20px);
        }
        .input-group label {
            display: block;
            margin-bottom: 8px;
            color: #555;
            font-weight: 500;
        }
        .input-group input {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 15px;
            transition: all 0.3s ease;
        }
        .input-group input:focus {
            border-color: #ff9a9e;
            outline: none;
            box-shadow: 0 0 8px rgba(255, 154, 158, 0.4);
        }
        .submit-btn {
            width: 100%;
            padding: 12px;
            background: #ff758c;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.3s;
            /* Initially hidden for GSAP */
            opacity: 0; 
        }
        .submit-btn:hover {
            background: #ff5e78;
        }
        .login-link {
            margin-top: 20px;
            font-size: 14px;
            color: #666;
            opacity: 0; /* Initially hidden for GSAP */
        }
        .login-link a {
            color: #ff758c;
            text-decoration: none;
            font-weight: 600;
        }
    </style>
</head>
<body>

    <div class="form-container">
        <h2 class="gsap-title">Join Urban Bites</h2>
        <form action="/signup" method="POST">
            <div class="input-group gsap-item">
                <label for="username">Username</label>
                <input type="text" id="username" name="username" placeholder="Enter your username" required>
            </div>
            <div class="input-group gsap-item">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="Enter your email" required>
            </div>
            <div class="input-group gsap-item">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="Create a password" required>
            </div>
            <button type="submit" class="submit-btn gsap-item">Sign Up</button>
        </form>
        <p class="login-link gsap-item">Already have an account? <a href="/login">Log In</a></p>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script>
        // GSAP Animations
        document.addEventListener("DOMContentLoaded", () => {
            // Animate the main container
            gsap.to(".form-container", {
                duration: 0.8,
                opacity: 1,
                y: 0,
                ease: "power3.out"
            });

            // Stagger the input fields, button, and link
            gsap.to(".gsap-item", {
                duration: 0.6,
                opacity: 1,
                y: 0,
                stagger: 0.15,
                ease: "back.out(1.7)",
                delay: 0.3
            });
        });
    </script>
</body>
</html>