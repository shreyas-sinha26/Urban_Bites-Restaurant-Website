<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Log In - Urban Bites</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }
        body {
            background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        .form-container {
            background: rgba(255, 255, 255, 0.95);
            padding: 40px 30px;
            border-radius: 15px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 400px;
            text-align: center;
            opacity: 0; 
            transform: scale(0.9);
        }
        .form-container h2 {
            font-size: 28px;
            color: #333;
            margin-bottom: 30px;
        }
        .input-group {
            margin-bottom: 20px;
            text-align: left;
            opacity: 0; 
            transform: translateX(-30px);
        }
        .input-group label {
            display: block;
            margin-bottom: 8px;
            color: #555;
            font-weight: 500;
        }
        .input-group input {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 15px;
            transition: all 0.3s ease;
        }
        .input-group input:focus {
            border-color: #a18cd1;
            outline: none;
            box-shadow: 0 0 8px rgba(161, 140, 209, 0.4);
        }
        .submit-btn {
            width: 100%;
            padding: 12px;
            background: #8e75c6;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.3s;
            opacity: 0; 
            transform: translateY(20px);
        }
        .submit-btn:hover {
            background: #755bb0;
        }
        .signup-link {
            margin-top: 20px;
            font-size: 14px;
            color: #666;
            opacity: 0; 
        }
        .signup-link a {
            color: #8e75c6;
            text-decoration: none;
            font-weight: 600;
        }
        /* Error messages style if needed */
        .error-message {
            color: #d9534f;
            background: #fdf7f7;
            padding: 10px;
            border-radius: 5px;
            margin-bottom: 15px;
            font-size: 14px;
        }
    </style>
</head>
<body>

    <div class="form-container">
        <h2>Welcome Back!</h2>
        
        <% if(typeof error !== 'undefined' && error.length > 0) { %>
            <div class="error-message"><%= error %></div>
        <% } %>

        <form action="/login" method="POST">
            <div class="input-group gsap-item">
                <label for="username">Username</label>
                <input type="text" id="username" name="username" placeholder="Enter your username" required>
            </div>
            <div class="input-group gsap-item">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="Enter your password" required>
            </div>
            <button type="submit" class="submit-btn gsap-btn">Log In</button>
        </form>
        <p class="signup-link gsap-link">Don't have an account? <a href="/signup">Sign Up</a></p>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // Container pop-in
            gsap.to(".form-container", {
                duration: 0.6,
                opacity: 1,
                scale: 1,
                ease: "back.out(1.5)"
            });

            // Slide inputs from the left
            gsap.to(".gsap-item", {
                duration: 0.5,
                opacity: 1,
                x: 0,
                stagger: 0.15,
                ease: "power2.out",
                delay: 0.2
            });

            // Slide button from the bottom
            gsap.to(".gsap-btn", {
                duration: 0.5,
                opacity: 1,
                y: 0,
                ease: "power2.out",
                delay: 0.6
            });

            // Fade in the link
            gsap.to(".gsap-link", {
                duration: 0.5,
                opacity: 1,
                delay: 0.8
            });
        });
    </script>
</body>
</html>